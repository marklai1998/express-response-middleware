{
  "name": "express-response-middleware",
  "version": "2.2.0",
  "description": "Transform an express response",
  "keywords": [
    "mung",
    "middleware",
    "transform",
    "response",
    "express"
  ],
  "homepage": "https://github.com/marklai1998/express-response-middleware#readme",
  "bugs": {
    "url": "https://github.com/marklai1998/express-response-middleware/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marklai1998/express-response-middleware"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --format esm --format cjs",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@marklai/shared-config-biome": "1.0.0",
    "@marklai/shared-config-commitlint": "1.0.5",
    "@marklai/shared-config-typescript": "1.1.0",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "lefthook": "2.1.9",
    "supertest": "7.2.2",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=18"
  }
}
